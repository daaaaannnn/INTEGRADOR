@startuml
skinparam componentStyle uml2
skinparam shadowing false
title Diagrama de Componentes - Gestión de Prácticas Académicas

package "Vista / Swing" {
  [LoginForm]
  [DirectorDashboard]
  [CoordinadorDashboard]
  [DocenteDashboard]
  [EstudianteDashboard]
  [InstitucionDashboard]
}

package "Controlador MVC" {
  [Controladores]
}

package "Lógica de Negocio" {
  [UsuarioLogica]
  [PracticaLogica]
  [GrupoLogica]
  [EvaluacionLogica]
  [RubricaLogica]
  [RegistroActividadLogica]
}

package "DAO" {
  [UsuarioDAO]
  [ProgramaDAO]
  [PracticaDAO]
  [GrupoDAO]
  [InstitucionDAO]
  [EvaluacionDAO]
  [RubricaDAO]
  [RegistroActividadDAO]
}

package "Modelo" {
  [Usuario]
  [Programa]
  [Practica]
  [Grupo]
  [Institucion]
  [MatriculaPractica]
  [Evaluacion]
  [Rubrica]
}

package "Utilidades" {
  [ConexionBD.java]
  [Utilidades.java]
}

package "Reportes" {
  [Generador PDF]
  [Exportador Excel]
}

database "Oracle XE 10g\nEsquema PROYECTOJD" as Oracle

[LoginForm] --> [Controladores]
[DirectorDashboard] --> [Controladores]
[CoordinadorDashboard] --> [Controladores]
[DocenteDashboard] --> [Controladores]
[EstudianteDashboard] --> [Controladores]
[InstitucionDashboard] --> [Controladores]

[Controladores] --> [UsuarioLogica]
[Controladores] --> [PracticaLogica]
[Controladores] --> [GrupoLogica]
[Controladores] --> [EvaluacionLogica]
[Controladores] --> [RubricaLogica]
[Controladores] --> [RegistroActividadLogica]

[UsuarioLogica] --> [UsuarioDAO]
[PracticaLogica] --> [PracticaDAO]
[GrupoLogica] --> [GrupoDAO]
[EvaluacionLogica] --> [EvaluacionDAO]
[RubricaLogica] --> [RubricaDAO]
[RegistroActividadLogica] --> [RegistroActividadDAO]

[UsuarioDAO] --> [ConexionBD.java]
[ProgramaDAO] --> [ConexionBD.java]
[PracticaDAO] --> [ConexionBD.java]
[GrupoDAO] --> [ConexionBD.java]
[InstitucionDAO] --> [ConexionBD.java]
[EvaluacionDAO] --> [ConexionBD.java]
[RubricaDAO] --> [ConexionBD.java]
[RegistroActividadDAO] --> [ConexionBD.java]

[ConexionBD.java] --> Oracle : JDBC / ojdbc14
[Controladores] ..> [Usuario]
[Controladores] ..> [Practica]
[DAO] ..> [Modelo]
[Generador PDF] --> [ReporteDAO]
[Exportador Excel] --> [ReporteDAO]
@enduml
