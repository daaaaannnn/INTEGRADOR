@startuml
skinparam shadowing false
title Diagrama de Despliegue - Gestión de Prácticas Académicas

node "Cliente / Usuario" {
  artifact "Interfaz gráfica Swing"
  artifact "Login por rol"
  artifact "Panel Director"
  artifact "Panel Coordinador"
  artifact "Panel Docente"
  artifact "Panel Estudiante"
  artifact "Panel Institución"
}

node "Equipo de Ejecución Java" {
  artifact "GestionPracticas.jar"
  artifact "JVM / JDK"
  artifact "Paquete vista"
  artifact "Paquete controlador"
  artifact "Paquete lógica"
  artifact "Paquete util"
}

node "Aplicación GestionPracticas" {
  component "Controladores MVC"
  component "Servicios / lógica de negocio"
  component "DAO: CRUD y consultas"
  component "Modelo: entidades"
  component "ConexionBD.java"
  component "Driver ojdbc14"
  component "Generador de reportes"
}

database "Servidor de Base de Datos\nOracle Database XE 10g\nEsquema PROYECTOJD" as DB
node "Repositorio y Respaldo" {
  artifact "GitHub"
  artifact "Scripts SQL"
  artifact "Copias de seguridad"
}
node "Salida" {
  artifact "PDF"
  artifact "Excel"
  artifact "Impresora"
}

"Cliente / Usuario" -- "Equipo de Ejecución Java" : interacción de usuario
"Equipo de Ejecución Java" -- "Aplicación GestionPracticas" : llamadas MVC
"Aplicación GestionPracticas" -- DB : JDBC / SQL
"Aplicación GestionPracticas" -- "Salida" : exporta reportes
"Aplicación GestionPracticas" .. "Repositorio y Respaldo" : versiona / respalda
@enduml
